# ─────────────────────────────────────────────────────────
#  TOSTADERO WELLINGTON — Variables de Entorno
#  Copiá este archivo a .env.local y completá los valores
# ─────────────────────────────────────────────────────────

# ── Mercado Pago ──────────────────────────────────────────
# Obtenelas en: mercadopago.com.ar → Developers → Tu aplicación
#
# Modo PRUEBA (para desarrollo local):
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxx-000000000
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000
#
# Modo PRODUCCIÓN (cuando estés listo para cobrar):
# MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxx-000000000
# NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000

# ── App ───────────────────────────────────────────────────
# URL base para los back_urls de Mercado Pago
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# Secret del webhook de Mercado Pago
# Se obtiene al activar webhooks en tu aplicación de Mercado Pago
MP_WEBHOOK_SECRET=tu-webhook-secret

# Clave opcional para proteger el panel interno del local
# Si se define, se pide en /local/pedidos?key=...
LOCAL_DASHBOARD_KEY=

# ── Supabase (opcional — para auth y pedidos) ─────────────
# Obtenelas en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# Alternativa moderna al service role JWT
SUPABASE_SECRET_KEY=sb_secret_xxxxx
